# Firebase Client Config (Publicly exposed)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin User Identification
NEXT_PUBLIC_ADMIN_UID=

# WAVE AI Chatbot Config
GROQ_API_KEY=

# CallMeBot WhatsApp Config
# In production, use CALLMEBOT_API_KEY (accessed server-side only).
CALLMEBOT_API_KEY=

# Twilio WhatsApp Config
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firebase Admin SDK Credentials (Required server-side in production)
# Optional in local development; if missing, falls back to local uploads & JWT decoding.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
